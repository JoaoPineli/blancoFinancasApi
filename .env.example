# Database Configuration
DATABASE_URL=

# Security
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# BCB API
BCB_API_BASE_URL=https://api.bcb.gov.br/dados/serie/bcdata.sgs

# Application
DEBUG=true
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:3000"]

# Frontend (used to build links in transactional emails — must be the public URL in production)
FRONTEND_URL=http://localhost:3000

# Sendgrid Configuration
SENDGRID_API_KEY= your-sendgrid-api-key

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_API_BASE_URL=https://api.mercadopago.com
MERCADOPAGO_WEBHOOK_TOLERANCE_SECONDS=300
# Email do pagador de teste (sandbox). Deve ser um test user comprador criado no painel MP.
# Em produção este campo é ignorado — o email real do usuário é usado automaticamente.
MERCADOPAGO_TEST_PAYER_EMAIL=
# URL pública que o MP chamará para notificações de pagamento (webhook por order).
# Em desenvolvimento: URL do ngrok, ex: https://abc123.ngrok-free.app/api/v1/admin/webhooks/mercadopago
# Em produção: URL pública do servidor, ex: https://api.blancofinancas.com.br/api/v1/admin/webhooks/mercadopago
# Se vazio, o MP usa a URL configurada no dashboard da integração (fallback).
MERCADOPAGO_NOTIFICATION_URL=